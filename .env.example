# ─── Supabase ────────────────────────────────────────────────────────────────
# Local dev values are printed by `pnpm db:start` (supabase start).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
# JWKS endpoint used by the NestJS API to verify Supabase-issued JWTs.
SUPABASE_JWT_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUD=authenticated

# ─── API (apps/api) ──────────────────────────────────────────────────────────
API_PORT=3000
API_PREFIX=api
API_VERSION=1
NODE_ENV=development

# ─── Web (apps/web) — Vite, must be prefixed with VITE_ ───────────────────────
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-local-anon-key
VITE_API_URL=http://127.0.0.1:3000/api/v1
VITE_SENTRY_DSN=
VITE_PUBLIC_URL=http://localhost:5173

# ─── Observability (optional) ────────────────────────────────────────────────
SENTRY_DSN=
